#/bin/bash

set -e

NO_LINK=false

for opt in $*; do
  case opt in
    --no-link)
        NO_LINK=true
    ;;
  esac
done

# Don't build the language server and talos for the moment, as these
# are a bit out of date.
for NAME in "daedalus" "dex"; do
    cabal build exe:$NAME
    mkdir -p bin
    VERSION="$(scripts/version $NAME)"
    BIN="bin/$NAME-$VERSION"
    if [ "$OS_TAG" != "" ]; then BIN="$BIN-$OS_TAG"; fi
    if [ "$ARCH_TAG" != "" ]; then BIN="$BIN-$ARCH_TAG"; fi
    cp $(cabal list-bin -v0 exe:$NAME) "$BIN"
    pushd "bin"
    ln -s -f $(basename "$BIN") "$NAME"
    popd
    echo $BIN
done

