
extern ->
  #include <ddl/unit.h>
  #include <ddl/bool.h>
  #include <ddl/number.h>
  #include <ddl/size.h>
  #include <ddl/array.h>
  #include <ddl/map.h>
  #include <ddl/maybe.h>
  #include <ddl/input.h>

  #include <cstdint>
  #include <vector>
  #include <string>
  #include <optional>
  #include <unordered_map>

type bool         -> bool
type char         -> char
type uint8_t      -> uint8_t
type int32_t      -> int32_t
type int64_t      -> int64_t
type vector<T>    -> std::vector<$T>
type string       -> std::string
type optional<T>  -> std::optional<T>
type map<K,V>     -> std::unordered_map<$K,$V>

default def as_uint8(x: uint 8): uint8_t = extern
default def as_int32(x: sint 32): int32_t = extern
default def as_int64(x: sint 64): int64_t = extern

default def as_bool(x: bool): bool =
  case x of
    true -> true
    false -> false

def as_optional<A,T,f: A => T>(x: maybe A): optional<T> =
  case x of
    nothing -> std::optional()
    just a  -> std::optional($(f(a))) 

def as_char(x: uint 8): char -> static_cast<char>($x)

def as_string (xs: [uint 8]): string =
  init -> std::string result;
  for x in xs -> result.push_back($(as_char(x)));
  return -> result

def as_vector<A, T, element: A => T>(xs: [A]): vector<T> =
  init -> std::vector<$T> xs;
  for x in xs -> xs.push_back($(element(x)));
  return -> xs

def as_map<K,V,X,Y, expK: K => X, expV: V => Y> (mp: [K:V]): map<X,Y> =
  init -> std::unordered_map xs;
  for k,v in mp -> xs.insert({$(expK(k)), $(expV(v))});
  return -> xs
