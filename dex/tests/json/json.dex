
daedalus json(JSON_value_strict)

extern ->
  #include <cstdint>
  #include <vector>
  #include <string>
  #include <option>
  #include <unordered_map>
  #include "json.hpp"

type bool       -> bool
type char       -> char
type uint8_t    -> uint8_t
type int32_t    -> int32_t
type int64_t    -> int64_t
type vector<T>  -> std::vector<$T>
type string     -> std::string
type option<T>  -> std::option<T>
type map<K,V>   -> std::unordered_map<$K,$V>
type JSON       -> basic_json<>
type void       -> void

default def uint8(x: uint 8): uint8_t = extern
default def int32(x: sint 32): int32_t = extern
default def int64(x: sint 64): int64_t = extern

default def as_bool(x: bool): bool =
  case x of
    true -> true
    false -> false

def as_option<A,T,f: A => T>(x: maybe A): option<T> =
  case x of
    nothing -> std::option()
    just a  -> std::option($(f(a))) 

def ignore<A>(x: A): void = extern

def as_char(x: uint 8): char -> static_cast<char>($x)



def as_string (xs: [uint 8]): string =
  init -> std::string result;
  for x in xs -> result.push_back($(as_char(x)));
  return -> result

def as_vector<A, T, element: A => T>(xs: [A]): vector<T> =
  init -> std::vector<$T> xs;
  for x in xs -> xs.push_back($(element(x)));
  return -> xs

def as_map<K,V,X,Y, expK: K => X, expV: V => Y> (mp: [K:V]): map<X,Y> =
  init -> std::unordered_map xs;
  for k,v in mp -> xs.insert({$(expK(k)), $(expV(v))});
  return -> xs

def exportJSON (x: JSON_value): JSON =
  case x of
    Null      -> basic_json<>(nullptr)
    Bool b    -> basic_json<>($b)
    Number n  = exportNumber(n)
    String s  -> basic_json<>($(as_string(s)))
    Array xs  -> basic_json<>($(as_vector<exportJSON>(xs)))
    Object xs -> basic_json<>($(as_map<as_string,exportJSON>(xs)))


-- Exporting a struct.  Here we use a local lambda to do some computation.
-- It might be better to name this on the C++ side, and keep things
-- simple in here.
def exportNumber(x: JSON_number): JSON ->
  [=] () mutable { 
    int64_t w = $(x.whole);
    int32_t e = $(x.exp);
    if (e < 0) return basic_json<>(w * std::pow(10,e));
    auto pos_e = exp10(static_cast<uint32_t>(e));
    if (w < 0) return basic_json<>(w * static_cast<int64_t>(pos_e));
    return basic_json<>(static_cast<uint64_t>(w) * pos_e);
  }()
