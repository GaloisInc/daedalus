// Test: MalformedExporter
// This test provides wrong number of arguments to an exporter

import spec(Main)

using CPP

extern ->
  #include "main_parser.h"
  #include <cstdint>

extern def ->
  #include "exporter.h"

type Result -> uint32_t

def exportWithConverter<conv: Main => Result>(x: Main): Result -> $(conv(x))

// Error: exportWithConverter expects 1 exporter argument, but given 0
def exportMain(x: Main): Result -> $(exportWithConverter(x))
