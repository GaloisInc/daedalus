import spec(Main)

using CPP

extern ->
  #include "main_parser.h"

extern def ->
  #include "exporter.h"

  namespace spec {
  uint64_t streamLen(DDL::Input x) { return x.length().rep(); }
  }

def streamLen(x: stream): uint64_t = extern

def exportMain(x: Main): uint64_t ->
  $(streamLen(x.data))
