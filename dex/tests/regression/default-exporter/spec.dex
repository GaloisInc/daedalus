import spec(Main)

using CPP

extern ->
  #include "main_parser.h"
  #include <string>

extern def ->
  #include "exporter.h"

type AppPair -> std::string

default def exportPair(x: Pair): AppPair ->
  std::to_string($(x.x)) + " " + std::to_string($(x.y))

def exportMain(x: Main): AppPair ->
  $(x.p)
