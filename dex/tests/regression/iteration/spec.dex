import spec(Main)

using CPP

extern ->
  #include "main_parser.h"
  #include <string>

extern def ->
  #include "exporter.h"

type Result -> std::string

def arrStats(xs: [uint 8]): Result =
  init   -> uint32_t count = 0; uint32_t sum = 0;
  for x in xs -> count++; sum += $(x);
  return -> std::to_string(count) + " " + std::to_string(sum)

def exportMain(x: Main): Result ->
  $(arrStats(x.arr))
