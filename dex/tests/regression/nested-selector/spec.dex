import spec(Main, Inner)

using CPP

extern ->
  #include "main_parser.h"
  #include <string>

extern def ->
  #include "exporter.h"

type Result -> std::string

def exportByte(x: uint 8): Result ->
  std::to_string($x)

def exportMain(x: Main): Result ->
  std::to_string($(x.tag)) + ": " + $(exportByte(x.inner.a)) 
                           + ", " + $(exportByte(x.inner.b)) 
   
                        
