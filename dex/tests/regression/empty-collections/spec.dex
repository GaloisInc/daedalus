import spec(Main)

using CPP

extern ->
  #include "main_parser.h"
  #include <string>

extern def ->
  #include "exporter.h"

type Result -> std::string

def arrCount(xs: [uint 8]): Result =
  init   -> uint32_t count = 0;
  for x in xs -> count += $(x) * 0 + 1;
  return -> std::to_string(count)

def mapCount(mp: [uint 8 : uint 8]): Result =
  init   -> uint32_t count = 0;
  for k,v in mp -> count += $(k) * 0 + $(v) * 0 + 1;
  return -> std::to_string(count)

def exportMain(x: Main): Result ->
  $(arrCount(x.arr)) + " " + $(mapCount(x.mp))
